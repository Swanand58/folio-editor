{
  "name": "folio-editor",
  "version": "0.3.0",
  "description": "A paginated document editor for React/Next.js — page breaks, table/paragraph splitting, editable headers/footers, print-ready output. Built on TipTap.",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "sideEffects": false,
  "files": [
    "dist/*.js",
    "dist/*.mjs",
    "dist/*.d.ts",
    "dist/*.d.mts",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "tiptap",
    "editor",
    "pagination",
    "page-break",
    "document",
    "print",
    "react",
    "nextjs",
    "prosemirror",
    "folio"
  ],
  "author": "Swanand Khonde",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Swanand58/folio-editor.git"
  },
  "bugs": {
    "url": "https://github.com/Swanand58/folio-editor/issues"
  },
  "homepage": "https://github.com/Swanand58/folio-editor#readme",
  "peerDependencies": {
    "@tiptap/core": "^2.0.0",
    "@tiptap/pm": "^2.0.0",
    "@tiptap/react": "^2.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "@tiptap/react": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tiptap/core": "^2.11.0",
    "@tiptap/extension-bold": "^2.11.0",
    "@tiptap/extension-bullet-list": "^2.11.0",
    "@tiptap/extension-document": "^2.11.0",
    "@tiptap/extension-heading": "^2.11.0",
    "@tiptap/extension-italic": "^2.11.0",
    "@tiptap/extension-list-item": "^2.11.0",
    "@tiptap/extension-ordered-list": "^2.11.0",
    "@tiptap/extension-paragraph": "^2.11.0",
    "@tiptap/extension-strike": "^2.11.0",
    "@tiptap/extension-table": "^2.27.2",
    "@tiptap/extension-table-cell": "^2.27.2",
    "@tiptap/extension-table-header": "^2.27.2",
    "@tiptap/extension-table-row": "^2.27.2",
    "@tiptap/extension-text": "^2.11.0",
    "@tiptap/extension-underline": "^2.11.0",
    "@tiptap/pm": "^2.11.0",
    "@tiptap/react": "^2.11.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.57.0",
    "vitest": "~3.0.0"
  }
}
